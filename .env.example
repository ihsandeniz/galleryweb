# GalleryWeb SaaS — Environment Variables
# Bu dosyayı .env olarak kopyala ve gerçek değerleri doldur:
# cp .env.example .env
# .env asla git'e commit edilmez!

# ─────────────────────────────────────────────
# SUPABASE
# https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ─────────────────────────────────────────────
# CLOUDFLARE R2
# https://dash.cloudflare.com → R2 → API Tokens
# ─────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=galleryweb-prod
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://gallery.yourdomain.com

# ─────────────────────────────────────────────
# PADDLE BILLING
# https://vendors.paddle.com → Developer Tools → Authentication
# ─────────────────────────────────────────────
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_ENVIRONMENT=sandbox    # sandbox | production
PADDLE_VIP1_PRICE_ID=pri_...  # VIP1 $4.99/mo price ID
PADDLE_VIP2_PRICE_ID=pri_...  # VIP2 $14.99/mo price ID
PADDLE_VIP3_PRICE_ID=pri_...  # VIP3 $49.99/mo price ID

# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
APP_ENV=development              # development | production
APP_SECRET_KEY=change-this-to-random-64-char-string
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─────────────────────────────────────────────
# STORAGE QUOTAS (GB)
# ─────────────────────────────────────────────
QUOTA_FREE_GB=5
QUOTA_VIP1_GB=50
QUOTA_VIP2_GB=500
QUOTA_VIP3_GB=5120

# ─────────────────────────────────────────────
# THUMBNAIL LAMBDA (Cloudflare Worker veya AWS Lambda)
# ─────────────────────────────────────────────
THUMBNAIL_WORKER_URL=https://gallery-thumbnail.your-account.workers.dev
THUMBNAIL_WORKER_SECRET=your-worker-secret-token

# ─────────────────────────────────────────────
# SENTRY (hata takibi — opsiyonel)
# https://sentry.io → yeni proje → DSN al
# ─────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─────────────────────────────────────────────
# RAILWAY (otomatik set eder — local geliştirme için gerekmez)
# ─────────────────────────────────────────────
# DATABASE_URL=postgresql://...  # Railway PostgreSQL addon (opsiyonel, Supabase yerine)
# PORT=8000                      # Railway tarafından set edilir
